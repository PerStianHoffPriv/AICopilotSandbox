{
  "name": "Copilot CLI Sandbox",
  "build": { "dockerfile": "Dockerfile" },
  "mounts": [
    "source=copilot-cli-auth,target=/home/node/.config/copilot,type=volume"
  ],
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [3000, 5173, 8000, 8080],
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/sandbox"
}
